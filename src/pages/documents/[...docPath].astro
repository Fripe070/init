---
import { NodeCompiler } from "@myriaddreamin/typst-ts-node-compiler";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import DocumentList from "../../components/DocumentList.astro";
import HomeLogo from "../../components/HomeLogo.astro";
import typstDocuments from "../../documents";
import Layout from "../../layouts/BaseLayout.astro";

export const getStaticPaths = (async () => {
  const paths = [];
  for (const docs of Object.values(typstDocuments)) {
    for (const doc of docs) {
      paths.push({
        params: { docPath: doc.path },
        props: { document: doc },
      });
    }
  }
  return paths;
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { document } = Astro.props as Props;

const compiler = await NodeCompiler.create({
  workspace: "init-documents",
  fontArgs: [{ fontPaths: ["init-documents/assets/fonts"] }],
});
const compiledSvg = compiler.svg({
  // Patched to not have pages
  mainFileContent: `#set page(height: auto)\n${document.content}`,
});
---

<Layout>
  <div class="flex flex-row w-full h-dvh">
    <div class="grow shrink flex overflow-y-auto overflow-x-hidden min-w-0">
      <div class="my-auto p-8 grow shrink">
        <HomeLogo />
        <DocumentList currentDocPath={document.path} />
      </div>
    </div>
    <div class="grow-0 w-full shrink-0 max-w-4xl overflow-y-auto bg-white text-black relative">
      <div class="typst-render" set:html={compiledSvg}></div>
    </div>
  </div>
</Layout>

<style>
  .typst-render > :global(.typst-doc) {
    color-scheme: light;
    min-width: var(--container-2xl);
    width: 100%;
    height: auto;
  }
</style>
